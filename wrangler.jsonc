{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inkchat",
  "main": "worker.js",
  "compatibility_date": "2026-05-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend",
    "binding": "ASSETS"
  },
  "workers_dev": true,
  "routes": [
    { "pattern": "chat.kindlemodshelf.me/*", "zone_name": "kindlemodshelf.me" }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
